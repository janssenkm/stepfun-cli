{
  "name": "@stepfun-ai/cli",
  "version": "0.1.1",
  "description": "StepFun Command Line Interface",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/janssenkm/stepfun-cli.git"
  },
  "bugs": {
    "url": "https://github.com/janssenkm/stepfun-cli/issues"
  },
  "homepage": "https://github.com/janssenkm/stepfun-cli#readme",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "bin": {
    "stepfun": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test test/*.test.js",
    "pkg": "npm run build && node scripts/pkg-binaries.js",
    "prepublishOnly": "npm run build"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "targets": [
      "node18-linux-x64",
      "node18-macos-x64",
      "node18-win-x64"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.3.2"
  }
}
